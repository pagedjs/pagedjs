{
  "name": "pagedjs",
  "version": "0.5.0",
  "description": "Chunks up a document into paged media flows and applies print styles",
  "author": "Fred Chasen",
  "license": "MIT",
  "homepage": "https://pagedmedia.org",
  "main": "dist/paged.js",
  "module": "src/index.js",
  "browser": "dist/paged.js",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@pagedjs/utils": "^0.2.0",
    "@pagedjs/chunker": "^0.2.0",
    "@pagedjs/polisher": "^0.2.0",
    "@pagedjs/previewer": "^0.2.0"
  },
  "devDependencies": {
    "@pagedjs/cli": "^0.2.0",
    "@rollup/plugin-commonjs": "^19.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.0.0",
    "chalk": "^4.1.1",
    "eslint": "^7.27.0",
    "jest-image-snapshot": "^6.4.0",
    "pdf-to-img": "^4.1.0",
    "vitest": "^3.0.0",
    "rimraf": "^3.0.2",
    "rollup": "^2.38.3",
    "rollup-plugin-license": "^2.1.0",
    "vite": "^6.0.0"
  },
  "scripts": {
    "build": "rollup -c",
    "start": "vite",
    "test": "npm run lint && npm run tests && npm run specs",
    "tests": "npm test -w @pagedjs/chunker",
    "specs": "vitest run --config specs/vitest.config.js",
    "pretest": "npm run build",
    "prepublishOnly": "npm run build",
    "watch": "vite build --watch",
    "lint": "eslint -c .eslintrc.json src packages/*/src specs",
    "docker": "docker build -t pagedmedia/pagedjs . && docker run -it --security-opt 'seccomp=docker/seccomp.json' -v $(pwd)/specs:/home/node/pagedjs/specs pagedmedia/pagedjs npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pagedjs/pagedjs.git"
  },
  "files": [
    "dist",
    "src"
  ]
}
